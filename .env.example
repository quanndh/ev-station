# Bỏ qua OCPP khi bắt đầu/kết thúc sạc (demo không có trụ; kết thúc = hoàn tất DB + thanh toán ngay).
# Dev: để trống OCPP_SERVICE_URL → app tự bỏ qua OCPP (tránh 503). Có URL mà chưa chạy CSMS → đặt true.
# Production: bật trụ thật → CHARGING_SKIP_OCPP=false + OCPP_* + CSMS chạy.
# CHARGING_SKIP_OCPP=true
# Bắt buộc luôn có ?t= trên /s/… (kể cả demo). Mặc định không set.
# STATION_QR_REQUIRE_TOKEN=true

# Demo: sau khi quét QR luôn vào trạm đã chọn (không mở URL trên QR)
# Chỉ cần một trong hai (hoặc cả hai); DEMO_MODE được map sang client trong next.config
DEMO_MODE=false
# NEXT_PUBLIC_DEMO_MODE=false
# Slug trạm demo khi API /api/demo/qr-redirect lỗi (vd. sai DEMO_STATION_ID trong DB)
# DEMO_STATION_SLUG=seed-tram-1
# NEXT_PUBLIC_DEMO_STATION_SLUG=seed-tram-1
# Id trạm cho API (mặc định trong code nếu bỏ trống)
DEMO_STATION_ID=

# Email user nội bộ gắn phiên sạc khi khách không đăng nhập (seed + runtime create)
# GUEST_CHARGING_USER_EMAIL=guest-charging@local

# ---- Web (apps/web / Vercel) ----
# URL public của app (vd. https://ev-station.vercel.app) — dùng API tạo QR admin; camera Android cần HTTPS.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Tên hiển thị trên poster QR in trạm (/qr-test). Mặc định: EV Green Station
# NEXT_PUBLIC_APP_DISPLAY_NAME=EV Green Station
# Tên ngắn PWA / tile màn hình (mặc định: EV Station)
# NEXT_PUBLIC_APP_SHORT_NAME=EV Station

# URL base tới CSMS OCPP service (dùng trong apps/web/src/lib/ocppClient.ts)
OCPP_SERVICE_URL=http://YOUR_SERVER_DOMAIN_OR_IP:9000
OCPP_API_KEY=your-ocpp-shared-secret

# QR token signing secret (apps/web/src/lib/qrToken.ts)
QR_SECRET=change-me-qr-secret
# Thời hạn token trên URL QR trạm (số ngày, tính từ lúc generate). Mặc định 365.
QR_STATION_TOKEN_TTL_DAYS=365

# Auth (optional for dev; strongly required in production)
AUTH_SECRET=change-me-auth-secret

# ---- DB (server-side when not using managed DB) ----
# Example Postgres URL for local/compose usage:
DATABASE_URL=postgresql://evstation:evstation@localhost:5432/evstation?schema=public
# Migration / generate: chạy từ root repo để đọc .env (pnpm db:migrate | pnpm db:generate)

